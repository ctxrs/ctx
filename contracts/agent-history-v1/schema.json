{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ctx.rs/contracts/agent-history-v1/schema.json",
  "title": "ctx Agent History Contract v1",
  "type": "object",
  "required": ["contractVersion", "schemaVersion", "operation"],
  "properties": {
    "contractVersion": { "const": "agent-history-v1" },
    "schemaVersion": { "const": 1 },
    "operation": {
      "enum": [
        "status",
        "init",
        "sources",
        "import",
        "sync",
        "search",
        "showEvent",
        "showSession",
        "locateEvent",
        "locateSession",
        "error"
      ]
    },
    "backend": { "$ref": "#/$defs/backend" },
    "status": { "$ref": "#/$defs/status" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/providerSource" }
    },
    "import": { "$ref": "#/$defs/importResult" },
    "search": { "$ref": "#/$defs/searchResult" },
    "event": { "$ref": "#/$defs/eventResult" },
    "session": { "$ref": "#/$defs/sessionResult" },
    "location": { "$ref": "#/$defs/locationResult" },
    "error": { "$ref": "#/$defs/agentHistoryError" }
  },
  "$defs": {
    "backend": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["local", "hosted"] },
        "dataRoot": { "type": ["string", "null"] },
        "baseUrl": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "status": {
      "type": "object",
      "required": ["initialized", "localOnly"],
      "properties": {
        "initialized": { "type": "boolean" },
        "localOnly": { "type": "boolean" },
        "readOnly": { "type": "boolean" },
        "dataRoot": { "type": ["string", "null"] },
        "indexedItems": { "type": "integer", "minimum": 0 },
        "indexedSources": { "type": "integer", "minimum": 0 },
        "catalogedSessions": { "type": "integer", "minimum": 0 },
        "pendingCatalogSessions": { "type": "integer", "minimum": 0 },
        "failedCatalogSessions": { "type": "integer", "minimum": 0 },
        "staleCatalogSessions": { "type": "integer", "minimum": 0 },
        "freshness": { "$ref": "#/$defs/freshness" },
        "semantic": { "$ref": "#/$defs/extensibleObject" },
        "daemon": { "$ref": "#/$defs/extensibleObject" }
      },
      "additionalProperties": true
    },
    "extensibleObject": {
      "type": "object",
      "additionalProperties": true
    },
    "providerSource": {
      "type": "object",
      "required": ["provider", "path", "status", "importable"],
      "properties": {
        "provider": { "type": "string" },
        "path": { "type": "string" },
        "exists": { "type": "boolean" },
        "sourceFormat": { "type": ["string", "null"] },
        "status": { "type": "string" },
        "importSupport": { "type": ["string", "null"] },
        "nativeImport": { "type": "boolean" },
        "importable": { "type": "boolean" },
        "unsupportedReason": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "importResult": {
      "type": "object",
      "required": ["resume", "totals"],
      "properties": {
        "resume": { "type": "boolean" },
        "resumeMode": { "type": ["string", "null"] },
        "totals": { "$ref": "#/$defs/totals" },
        "sources": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      },
      "additionalProperties": true
    },
    "searchLexicalClause": {
      "oneOf": [
        {
          "type": "object",
          "required": ["all"],
          "properties": { "all": { "type": "string", "minLength": 1, "maxLength": 1024 } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["phrase"],
          "properties": { "phrase": { "type": "string", "minLength": 1, "maxLength": 1024 } },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["literal"],
          "properties": {
            "literal": {
              "type": "string",
              "minLength": 1,
              "maxLength": 256,
              "description": "Runtime validation requires 3..=256 UTF-8 bytes, an indexed anchor, and at most 32 analyzed tokens. JSON Schema string lengths count Unicode code points."
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "searchSemanticClause": {
      "type": "object",
      "required": ["semantic"],
      "properties": { "semantic": { "type": "string", "minLength": 1, "maxLength": 1024 } },
      "additionalProperties": false
    },
    "searchAnyClause": {
      "oneOf": [
        { "$ref": "#/$defs/searchLexicalClause" },
        { "$ref": "#/$defs/searchSemanticClause" }
      ]
    },
    "searchQueryV1": {
      "type": "object",
      "required": ["version"],
      "properties": {
        "version": { "const": "ctx-search-v1" },
        "any": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/searchAnyClause" },
          "contains": { "$ref": "#/$defs/searchSemanticClause" },
          "minContains": 0,
          "maxContains": 1
        },
        "must": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/searchLexicalClause" }
        },
        "must_not": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/searchLexicalClause" }
        }
      },
      "anyOf": [
        { "required": ["any"], "properties": { "any": { "minItems": 1 } } },
        { "required": ["must"], "properties": { "must": { "minItems": 1 } } }
      ],
      "additionalProperties": false
    },
    "searchExecutionLimits": {
      "type": "object",
      "required": [
        "query_bytes", "clauses", "analyzed_tokens_per_clause",
        "candidates_per_positive_seed", "candidate_rows", "retained_candidate_ids",
        "residual_rows", "verification_bytes", "verification_lookup_bytes",
        "hydrated_rows", "hydration_input_bytes", "hydration_input_bytes_per_event",
        "returned_text_bytes", "serialized_response_bytes", "results", "elapsed_ms"
      ],
      "properties": {
        "query_bytes": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "clauses": { "type": "integer", "minimum": 1, "maximum": 32 },
        "analyzed_tokens_per_clause": { "type": "integer", "minimum": 1, "maximum": 32 },
        "candidates_per_positive_seed": { "type": "integer", "minimum": 1, "maximum": 1024 },
        "candidate_rows": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "retained_candidate_ids": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "residual_rows": { "type": "integer", "minimum": 1, "maximum": 8192 },
        "verification_bytes": { "type": "integer", "minimum": 1, "maximum": 16777216 },
        "verification_lookup_bytes": { "type": "integer", "minimum": 1, "maximum": 16384 },
        "hydrated_rows": { "type": "integer", "minimum": 1, "maximum": 256 },
        "hydration_input_bytes": { "type": "integer", "minimum": 1, "maximum": 8388608 },
        "hydration_input_bytes_per_event": { "type": "integer", "minimum": 1, "maximum": 65536 },
        "returned_text_bytes": { "type": "integer", "minimum": 1, "maximum": 524288 },
        "serialized_response_bytes": { "type": "integer", "minimum": 1, "maximum": 2097152 },
        "results": { "type": "integer", "minimum": 1, "maximum": 200 },
        "elapsed_ms": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "searchExecutionConsumption": {
      "type": "object",
      "required": [
        "query_bytes", "clauses", "analyzed_tokens", "candidate_rows",
        "retained_candidate_ids", "residual_rows", "hydrated_rows",
        "legacy_fallback_rows", "verification_bytes", "largest_verification_lookup_bytes",
        "hydration_input_bytes", "largest_hydration_input_bytes", "returned_results",
        "returned_text_bytes", "serialized_response_bytes", "elapsed_ms"
      ],
      "properties": {
        "query_bytes": { "type": "integer", "minimum": 0 },
        "clauses": { "type": "integer", "minimum": 0 },
        "analyzed_tokens": { "type": "integer", "minimum": 0 },
        "candidate_rows": { "type": "integer", "minimum": 0 },
        "retained_candidate_ids": { "type": "integer", "minimum": 0 },
        "residual_rows": { "type": "integer", "minimum": 0 },
        "hydrated_rows": { "type": "integer", "minimum": 0 },
        "legacy_fallback_rows": { "type": "integer", "minimum": 0 },
        "verification_bytes": { "type": "integer", "minimum": 0 },
        "largest_verification_lookup_bytes": { "type": "integer", "minimum": 0 },
        "hydration_input_bytes": { "type": "integer", "minimum": 0 },
        "largest_hydration_input_bytes": { "type": "integer", "minimum": 0 },
        "returned_results": { "type": "integer", "minimum": 0 },
        "returned_text_bytes": { "type": "integer", "minimum": 0 },
        "serialized_response_bytes": { "type": "integer", "minimum": 0 },
        "elapsed_ms": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "searchSemanticCoverage": {
      "type": "object",
      "required": ["candidates_supplied", "candidates_consumed", "candidates_used", "truncated"],
      "properties": {
        "candidates_supplied": { "type": "integer", "minimum": 0 },
        "candidates_consumed": { "type": "integer", "minimum": 0 },
        "candidates_used": { "type": "integer", "minimum": 0 },
        "truncated": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "searchSemanticDiagnostics": {
      "type": "object",
      "required": [
        "attempted", "required", "readiness", "effective_backend", "coverage",
        "completeness", "positive_text_rule_version"
      ],
      "properties": {
        "attempted": { "type": "boolean" },
        "required": { "type": "boolean" },
        "readiness": { "enum": ["ready", "not_ready", "unsupported", "unavailable"] },
        "effective_backend": { "enum": ["none", "lexical", "semantic", "hybrid"] },
        "backend": { "type": "string" },
        "coverage": { "$ref": "#/$defs/searchSemanticCoverage" },
        "completeness": { "enum": ["not_attempted", "complete", "partial", "skipped"] },
        "skip_reason": {
          "enum": ["disabled", "unavailable", "not_ready", "unsupported", "no_lexical_candidates"]
        },
        "positive_text_rule_version": { "const": "ctx-search-positive-text-v1" }
      },
      "additionalProperties": false
    },
    "searchExecution": {
      "type": "object",
      "required": [
        "query_version", "candidate_strategy", "resolved", "consumed", "semantic",
        "rrf_k", "per_branch_candidate_rows", "clauses_executed", "verification_dropped",
        "filter_verification_dropped", "candidate_budget_exhausted", "timed_out", "truncated"
      ],
      "properties": {
        "query_version": { "const": "ctx-search-v1" },
        "candidate_strategy": { "type": "string" },
        "resolved": { "$ref": "#/$defs/searchExecutionLimits" },
        "consumed": { "$ref": "#/$defs/searchExecutionConsumption" },
        "semantic": { "$ref": "#/$defs/searchSemanticDiagnostics" },
        "rrf_k": { "type": "integer", "minimum": 1 },
        "per_branch_candidate_rows": { "type": "integer", "minimum": 0 },
        "clauses_executed": { "type": "integer", "minimum": 0 },
        "verification_dropped": { "type": "integer", "minimum": 0 },
        "filter_verification_dropped": { "type": "integer", "minimum": 0 },
        "candidate_budget_exhausted": { "type": "boolean" },
        "timed_out": { "type": "boolean" },
        "truncated": { "type": "boolean" },
        "truncation_reasons": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "searchResult": {
      "type": "object",
      "required": ["query", "results", "query_execution"],
      "properties": {
        "query": {
          "oneOf": [
            { "$ref": "#/$defs/searchQueryV1" },
            { "type": "null" }
          ]
        },
        "filters": { "type": "object", "additionalProperties": true },
        "freshness": { "$ref": "#/$defs/freshness" },
        "retrieval": { "$ref": "#/$defs/searchRetrieval" },
        "generatedAt": { "type": ["string", "null"] },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/searchHit" }
        },
        "pagination": { "type": "object", "additionalProperties": true },
        "truncation": { "type": "object", "additionalProperties": true },
        "query_execution": { "$ref": "#/$defs/searchExecution" }
      },
      "additionalProperties": true
    },
    "searchHit": {
      "type": "object",
      "required": ["resultScope"],
      "properties": {
        "ctxEventId": { "type": ["string", "null"] },
        "ctxSessionId": { "type": ["string", "null"] },
        "providerSessionId": { "type": ["string", "null"] },
        "eventSeq": { "type": ["integer", "null"] },
        "title": { "type": ["string", "null"] },
        "snippet": { "type": ["string", "null"] },
        "rank": { "type": ["number", "null"] },
        "resultType": { "type": ["string", "null"] },
        "resultScope": { "type": "string" },
        "provider": { "type": ["string", "null"] },
        "timestamp": { "type": ["string", "null"] },
        "cwd": { "type": ["string", "null"] },
        "sourcePath": { "type": ["string", "null"] },
        "sourceExists": { "type": ["boolean", "null"] },
        "cursor": { "type": ["string", "null"] },
        "whyMatched": {
          "type": "array",
          "items": { "type": "string" }
        },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/citation" }
        },
        "suggestedNextCommands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "visibility": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "searchRetrieval": {
      "type": "object",
      "properties": {
        "requestedMode": {
          "type": ["string", "null"],
          "enum": ["hybrid", "semantic", "lexical", null]
        },
        "effectiveMode": {
          "type": ["string", "null"],
          "enum": ["lexical", "semantic", "hybrid", null]
        },
        "semanticStatus": { "type": ["string", "null"] },
        "embeddingModel": { "type": ["string", "null"] },
        "coverage": {
          "type": "object",
          "properties": {
            "embeddedItems": { "type": "integer", "minimum": 0 },
            "embeddedChunks": { "type": "integer", "minimum": 0 },
            "searchableItems": { "type": "integer", "minimum": 0 },
            "indexedNow": { "type": "integer", "minimum": 0 },
            "dirtyItems": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "worker": { "type": ["object", "null"], "additionalProperties": true },
        "diagnostics": { "type": ["object", "null"], "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "eventResult": {
      "type": "object",
      "required": ["events"],
      "properties": {
        "event": { "$ref": "#/$defs/event" },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/event" }
        },
        "source": { "$ref": "#/$defs/sourceLocation" }
      },
      "additionalProperties": true
    },
    "sessionResult": {
      "type": "object",
      "properties": {
        "session": { "type": "object", "additionalProperties": true },
        "events": {
          "type": "array",
          "items": { "$ref": "#/$defs/event" }
        },
        "source": { "$ref": "#/$defs/sourceLocation" },
        "mode": { "type": ["string", "null"] },
        "format": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "event": {
      "type": "object",
      "properties": {
        "ctxEventId": { "type": ["string", "null"] },
        "ctxSessionId": { "type": ["string", "null"] },
        "sequence": { "type": ["integer", "null"] },
        "eventType": { "type": ["string", "null"] },
        "role": { "type": ["string", "null"] },
        "occurredAt": { "type": ["string", "null"] },
        "source": { "type": ["string", "null"] },
        "cursor": { "type": ["string", "null"] },
        "text": { "type": ["string", "null"] },
        "preview": { "type": ["string", "null"] },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/citation" }
        }
      },
      "additionalProperties": true
    },
    "locationResult": {
      "type": "object",
      "required": ["ctxSessionId", "provider", "source"],
      "properties": {
        "ctxSessionId": { "type": "string" },
        "ctxEventId": { "type": ["string", "null"] },
        "provider": { "type": "string" },
        "providerSessionId": { "type": ["string", "null"] },
        "source": { "$ref": "#/$defs/sourceLocation" },
        "resume": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "sourceLocation": {
      "type": "object",
      "properties": {
        "path": { "type": ["string", "null"] },
        "cursor": { "type": ["string", "null"] },
        "exists": { "type": ["boolean", "null"] },
        "sourceId": { "type": ["string", "null"] },
        "sourceFormat": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "freshness": {
      "type": "object",
      "properties": {
        "mode": { "type": ["string", "null"] },
        "status": { "type": ["string", "null"] },
        "reason": { "type": ["string", "null"] },
        "budgetReasons": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "sourceCount": { "type": ["integer", "null"], "minimum": 0 },
        "daemonLastRunAtMs": { "type": ["integer", "null"] },
        "totals": { "$ref": "#/$defs/totals" },
        "error": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "citation": {
      "type": "object",
      "properties": {
        "itemId": { "type": ["string", "null"] },
        "targetType": { "type": ["string", "null"] },
        "ctxEventId": { "type": ["string", "null"] },
        "ctxSessionId": { "type": ["string", "null"] },
        "label": { "type": ["string", "null"] },
        "time": { "type": ["string", "null"] },
        "provider": { "type": ["string", "null"] },
        "sessionId": { "type": ["string", "null"] },
        "eventSeq": { "type": ["integer", "null"] },
        "sourcePath": { "type": ["string", "null"] },
        "sourceExists": { "type": ["boolean", "null"] },
        "cursor": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    },
    "totals": {
      "type": "object",
      "properties": {
        "sourceFiles": { "type": "integer", "minimum": 0 },
        "sourceBytes": { "type": "integer", "minimum": 0 },
        "importedSources": { "type": "integer", "minimum": 0 },
        "failedSources": { "type": "integer", "minimum": 0 },
        "importedSessions": { "type": "integer", "minimum": 0 },
        "importedEvents": { "type": "integer", "minimum": 0 },
        "importedEdges": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "agentHistoryError": {
      "type": "object",
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "enum": [
            "invalid_request",
            "not_found",
            "not_initialized",
            "backend_unavailable",
            "timeout",
            "cancelled",
            "not_supported",
            "adapter_error",
            "decode_error",
            "unknown"
          ]
        },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "details": { "type": "object", "additionalProperties": true },
        "cause": { "type": ["string", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
