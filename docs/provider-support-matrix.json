        "script": "scripts/release-provider-live-e2e-lanes.sh run codex",
        "required_env": [
          "CTX_LIVE_PROVIDER_E2E=1",
          "CTX_LIVE_PROVIDER_ACCEPT_LOCAL_HISTORY=1",
          "CTX_LIVE_PROVIDER_CODEX=1",
          "CTX_LIVE_PROVIDER_CODEX_SESSIONS_PATH",
          "CTX_LIVE_PROVIDER_CODEX_QUERY or CTX_LIVE_PROVIDER_QUERY"
