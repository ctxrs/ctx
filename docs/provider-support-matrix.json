        ],
        "artifacts": [
          "live-e2e.json",
          "live-e2e.md"
        ],
        "redaction": [
          "aggregate and oracle counts only",
          "no raw transcripts",
          "no raw snippets",
          "no raw queries",
          "no raw source paths",
          "provider-filter, citation, source_exists, and retrieval oracle counts only"
        ]
      },
