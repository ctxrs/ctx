{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.ctx.rs/plugins/plugin-manifest.v1.schema.json",
  "title": "PluginManifest",
  "description": "ctx plugin manifest schema.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version"],
  "allOf": [
    {
      "anyOf": [
        {
          "required": ["entrypoints"],
          "properties": {
            "entrypoints": {
              "minItems": 1
            }
          }
        },
        {
          "required": ["contributes"],
          "properties": {
            "contributes": {
              "$ref": "#/$defs/NonEmptyPluginContributions"
            }
          }
        }
      ]
    }
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1,
      "default": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": ["string", "null"]
    },
    "entrypoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/PluginEntrypoint"
      },
      "default": []
    },
    "contributes": {
      "$ref": "#/$defs/PluginContributions"
    },
    "compatibility": {
      "$ref": "#/$defs/PluginCompatibility"
    }
  },
  "$defs": {
    "StringArray": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "Environment": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "default": {}
    },
    "PluginEntrypointKind": {
      "type": "string",
      "enum": ["process", "worker", "webview"]
    },
    "PluginEntrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "command"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "$ref": "#/$defs/PluginEntrypointKind",
          "default": "process"
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "$ref": "#/$defs/StringArray"
        },
        "cwd": {
          "type": ["string", "null"]
        },
        "environment": {
          "$ref": "#/$defs/Environment"
        }
      }
    },
    "PluginProviderContribution": {
      "$ref": "#/$defs/NamedPluginContribution"
    },
    "PluginRuntimeContribution": {
      "$ref": "#/$defs/NamedPluginContribution"
    },
    "PluginCommandContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "category": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        }
      }
    },
    "PluginCollectorContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "events": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "PluginObserverContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "events": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "PluginUiSurfaceKind": {
      "type": "string",
      "enum": ["panel", "sidebar", "status_bar", "command_palette", "settings"]
    },
    "PluginUiSurfaceContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "surface"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "surface": {
          "$ref": "#/$defs/PluginUiSurfaceKind"
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "contexts": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "NamedPluginContribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": ["string", "null"]
        },
        "entrypoint": {
          "type": ["string", "null"]
        },
        "capabilities": {
          "$ref": "#/$defs/StringArray"
        }
      }
    },
    "PluginContributions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "providers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginProviderContribution"
          },
          "default": []
        },
        "runtimes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginRuntimeContribution"
          },
          "default": []
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginCommandContribution"
          },
          "default": []
        },
        "collectors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginCollectorContribution"
          },
          "default": []
        },
        "observers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginObserverContribution"
          },
          "default": []
        },
        "ui_surfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PluginUiSurfaceContribution"
          },
          "default": []
        }
      },
      "default": {}
    },
    "NonEmptyPluginContributions": {
      "allOf": [
        {
          "$ref": "#/$defs/PluginContributions"
        },
        {
          "anyOf": [
            {
              "required": ["providers"],
              "properties": {
                "providers": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["runtimes"],
              "properties": {
                "runtimes": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["commands"],
              "properties": {
                "commands": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["collectors"],
              "properties": {
                "collectors": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["observers"],
              "properties": {
                "observers": {
                  "minItems": 1
                }
              }
            },
            {
              "required": ["ui_surfaces"],
              "properties": {
                "ui_surfaces": {
                  "minItems": 1
                }
              }
            }
          ]
        }
      ]
    },
    "PluginCompatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_ctx_version": {
          "type": ["string", "null"]
        },
        "capabilities": {
          "$ref": "#/$defs/StringArray"
        }
      },
      "default": {}
    }
  }
}
